---
const stats = [
  { value: "US$ 700 MM+", label: "Millones financiados" },
  { value: "180.000 +", label: "Facturas operadas" },
  { value: "3.000 +", label: "Clientes" }
];
---
<section class="relative z-20 -mt-16 mb-20 px-4">
  <div class="max-w-5xl mx-auto bg-white rounded-[3rem] shadow-xl border border-gray-100 p-8 md:p-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 divide-y md:divide-y-0 md:divide-x divide-gray-100">
      {stats.map((stat) => (
        <div class="text-center px-4 pt-6 md:pt-0 first:pt-0">
          <h3 class="text-3xl md:text-4xl font-extrabold text-black mb-2">{stat.value}</h3>
          <p class="text-brand-primary font-medium text-xl">{stat.label}</p>
        </div>
      ))}
    </div>
  </div>
</section>