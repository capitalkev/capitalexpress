---
// Definimos los datos de los 4 slides
const slides = [
  {
    title: "¿Necesitas capital <br/> para tu pyme?",
    subtitle: "Acelera el flujo de caja de tu empresa",
    img: "/trabajador.png", 
    alt: "Hombre con delantal usando tablet"
  },
  {
    title: "Mantén tus <br/> cuentas claras",
    subtitle: "Simula con Capital Express.",
    img: "/trabajador2.png", 
    alt: "Mujer con saco amarillo revisando celular"
  },
  {
    title: "Te otorgamos <br/> Factoring",
    subtitle: "Seguro y en menos de 24 hrs.",
    img: "/trabajador3.png", 
    alt: "Trabajador con casco y mascarilla"
  },
  {
    title: "Impulsa tu <br/> crecimiento",
    subtitle: "Financiamiento a la medida de tu negocio.",
    img: "/trabajador4.png",
    alt: "Cuarta persona"
  }
];
---

<section class="relative pt-32 pb-20 lg:pt-48 lg:pb-32 overflow-hidden bg-gradient-to-r from-red-50 to-[#F5F5F5] select-none">
  
  <div class="hidden lg:flex flex-col gap-4 absolute left-6 top-1/2 -translate-y-1/2 z-20">
    <a href="#" class="w-10 h-10 rounded-lg bg-brand-primary text-white flex items-center justify-center hover:opacity-80 transition-opacity">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect width="4" height="12" x="2" y="9"/><circle cx="4" cy="4" r="2"/></svg>
    </a>
    <a href="#" class="w-10 h-10 rounded-lg bg-brand-primary text-white flex items-center justify-center hover:opacity-80 transition-opacity">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="20" x="2" y="2" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/></svg>
    </a>
  </div>

  <div class="max-w-7xl mx-auto relative z-10">
    <div id="hero-carousel" class="relative overflow-hidden touch-pan-y">
      <div id="hero-track" class="flex transition-transform duration-500 ease-out w-full">
        
        {slides.map((slide) => (
          <div class="w-full flex-shrink-0 grid lg:grid-cols-2 gap-12 items-center px-4 sm:px-6 lg:px-8">
            
            <div class="max-w-2xl pt-10 lg:pt-0">
              <h1 class="text-5xl lg:text-7xl font-extrabold leading-[1.1] mb-4 text-black tracking-tight" set:html={slide.title}></h1>
              <p class="text-xl text-gray-600 mb-8 max-w-lg font-medium">{slide.subtitle}</p>
              <div class="flex flex-wrap gap-4">
                <a href="/enrolate" class="px-8 py-3 rounded-full bg-brand-primary text-white font-bold text-lg hover:opacity-90 transition-all flex items-center gap-2 shadow-lg hover:shadow-xl transform hover:-translate-y-0.5 duration-200 cursor-pointer">
                  haz la prueba hoy
                </a>
              </div>
            </div>

            <div class="relative flex justify-end items-center">
              
              <img 
                src={slide.img} 
                alt={slide.alt} 
                class="relative z-10 object-contain drop-shadow-2xl pointer-events-none image-float"
              />
            </div>
          </div>
        ))}

      </div>
    </div>

    <div class="absolute bottom-[-30px] lg:bottom-10 left-1/2 -translate-x-1/2 flex gap-3 z-20">
      {slides.map((_, index) => (
        <button 
          class={`carousel-dot w-3 h-3 rounded-full transition-all duration-300 ${index === 0 ? 'bg-brand-primary w-8' : 'bg-gray-300 hover:bg-gray-400'}`}
          data-index={index}
          aria-label={`Ir al slide ${index + 1}`}
        ></button>
      ))}
    </div>
  </div>
</section>

<style>
  .clip-left { clip-path: polygon(0 0, 50% 0, 50% 100%, 0 100%); }
  .clip-right { clip-path: polygon(50% 0, 100% 0, 100% 100%, 50% 100%); }

  @keyframes float {
    0% { transform: translateY(0px); }
    50% { transform: translateY(-10px); }
    100% { transform: translateY(0px); }
  }
  .image-float {
    animation: float 6s ease-in-out infinite;
  }
</style>

<script>
  // Lógica del carrusel (Vanilla JS)
  const track = document.getElementById('hero-track');
  const dots = document.querySelectorAll('.carousel-dot');
  let currentIndex = 0;
  const totalSlides = dots.length;
  
  // Variables para gestos táctiles
  let startX = 0;
  let currentTranslate = 0;
  let isDragging = false;
  let autoPlayInterval;

  function updateSlider(index) {
    currentIndex = index;
    // Mueve la pista
    track.style.transform = `translateX(-${currentIndex * 100}%)`;
    
    // Actualiza los puntos
    dots.forEach((dot, i) => {
      if (i === currentIndex) {
        dot.classList.add('bg-brand-primary', 'w-8');
        dot.classList.remove('bg-gray-300');
      } else {
        dot.classList.remove('bg-brand-primary', 'w-8');
        dot.classList.add('bg-gray-300');
      }
    });
  }

  function nextSlide() {
    updateSlider((currentIndex + 1) % totalSlides);
  }

  function prevSlide() {
    updateSlider((currentIndex - 1 + totalSlides) % totalSlides);
  }

  // Click en los puntos
  dots.forEach(dot => {
    dot.addEventListener('click', (e) => {
      const index = parseInt((e.target as HTMLElement).dataset.index);
      updateSlider(index);
      resetAutoPlay();
    });
  });

  // --- Soporte para deslizar en móviles (Touch Events) ---
  const carousel = document.getElementById('hero-carousel');

  if (carousel) {
    carousel.addEventListener('touchstart', (e) => {
      startX = e.touches[0].clientX;
      isDragging = true;
      resetAutoPlay(); // Pausar autoplay al tocar
    }, { passive: true });

    carousel.addEventListener('touchmove', (e) => {
      if (!isDragging) return;
    }, { passive: true });

    carousel.addEventListener('touchend', (e) => {
      isDragging = false;
      const endX = e.changedTouches[0].clientX;
      const diff = startX - endX;

      // Si el deslizamiento es mayor a 50px
      if (Math.abs(diff) > 50) {
        if (diff > 0) {
          nextSlide(); // Deslizó hacia la izquierda
        } else {
          prevSlide(); // Deslizó hacia la derecha
        }
      }
    });
  }

  // Autoplay (cambia cada 5 segundos)
  function startAutoPlay() {
    autoPlayInterval = setInterval(nextSlide, 5000);
  }

  function resetAutoPlay() {
    clearInterval(autoPlayInterval);
    startAutoPlay();
  }

  // Iniciar carrusel
  startAutoPlay();
</script>