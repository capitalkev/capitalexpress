---
// Definimos los datos de los 4 slides
const slides = [
  {
    title: "Te otorgamos <br/> Factoring",
    subtitle: "Seguro y en menos de 24 hrs.",
    img: "/trabajador.png", // Trabajador
    alt: "Trabajador con casco"
  },
  {
    title: "¿Necesitas capital <br/> para tu pyme?",
    subtitle: "Acelera el flujo de caja de tu empresa.",
    img: "/trabajador2.png", // Hombre con delantal
    alt: "Hombre con delantal"
  },
  {
    title: "¿Necesitas liquidez <br/> para tu pyme?",
    subtitle: "En Capital Express te ayudamos.",
    img: "/trabajador3.png", // Mujer con laptop
    alt: "Mujer con laptop"
  },
  {
    title: "Mantén tus <br/> cuentas claras",
    subtitle: "Simula con Capital Express.",
    img: "/trabajador4.png", // Mujer de amarillo
    alt: "Mujer con saco amarillo revisando celular"
  },
];
---

<section class="relative pt-32 pb-24 lg:pt-48 lg:pb-36 overflow-hidden bg-gradient-to-r from-[#FFF1F1] to-[#F5F5F5] select-none w-full">
  
  <div class="hidden lg:flex flex-col gap-4 absolute left-6 top-1/2 -translate-y-1/2 z-30">
    <a href="https://www.linkedin.com/company/capitalexpress-servicios-financieros/" target="_blank" class="w-10 h-10 rounded-lg bg-brand-primary text-white flex items-center justify-center hover:opacity-80 transition-opacity shadow-md">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect width="4" height="12" x="2" y="9"/><circle cx="4" cy="4" r="2"/></svg>
    </a>
    <a href="#" target="_blank" class="w-10 h-10 rounded-lg bg-brand-primary text-white flex items-center justify-center hover:opacity-80 transition-opacity shadow-md">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="20" x="2" y="2" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/></svg>
    </a>
  </div>

  <div id="hero-carousel" class="w-full relative touch-pan-y cursor-grab active:cursor-grabbing z-10 grid">
    
    {slides.map((slide, index) => (
      <div class={`hero-slide col-start-1 row-start-1 w-full flex justify-center items-center transition-opacity duration-700 ${index === 0 ? 'active opacity-100 z-10' : 'opacity-0 z-0'}`} data-index={index}>
        
        <div class="max-w-7xl w-full grid lg:grid-cols-2 gap-12 items-center px-4 sm:px-6 lg:px-8">
          
          <div class="slide-text max-w-2xl pt-10 lg:pt-0 pointer-events-auto transition-all duration-1000 ease-out transform -translate-x-16 opacity-0">
            <h1 class="text-5xl lg:text-7xl font-extrabold leading-[1.1] mb-4 text-black tracking-tight" set:html={slide.title}></h1>
            <p class="text-xl text-brand-secondary mb-8 max-w-lg font-medium">{slide.subtitle}</p>
            <div class="flex flex-wrap gap-4 pointer-events-auto">
              <a href="/enrolate" class="px-24 rounded-full bg-brand-primary text-white font-bold text-lg hover:bg-red-600 transition-colors flex items-center gap-2 shadow-lg">
                haz la prueba hoy
              </a>
            </div>
          </div>

          <div class="slide-image relative flex justify-end items-center h-[400px] lg:h-[500px] pointer-events-none transition-all duration-1000 ease-out transform translate-x-16 opacity-0">
   
            <img 
              src={slide.img} 
              alt={slide.alt} 
              class="relative z-10 h-[450px] lg:h-[550px] object-contain drop-shadow-2xl image-float"
            />
          </div>
        </div>

      </div>
    ))}
  </div>

  <div class="absolute bottom-6 left-1/2 -translate-x-1/2 flex gap-3 z-20">
    {slides.map((_, index) => (
      <button 
        class={`carousel-dot w-2.5 h-2.5 rounded-full transition-colors duration-300 ${index === 0 ? 'bg-brand-primary' : 'bg-gray-300 hover:bg-gray-400'}`}
        data-index={index}
        aria-label={`Ir al slide ${index + 1}`}
      ></button>
    ))}
  </div>
</section>

<style>
  /* Animaciones de entrada del slide activo */
  .hero-slide.active .slide-text,
  .hero-slide.active .slide-image {
    transform: translateX(0);
    opacity: 1;
  }

  /* Prevenir que slides invisibles sean clickeables */
  .hero-slide:not(.active) {
    pointer-events: none;
  }

  /* Recortes de los círculos del logo */
  .clip-left { clip-path: polygon(0 0, 50% 0, 50% 100%, 0 100%); }
  .clip-right { clip-path: polygon(50% 0, 100% 0, 100% 100%, 50% 100%); }

  /* Animación de flote para imágenes */
  @keyframes float {
    0% { transform: translateY(0px); }
    50% { transform: translateY(-8px); }
    100% { transform: translateY(0px); }
  }
  .image-float {
    animation: float 6s ease-in-out infinite;
  }
</style>

<script>
  const slides = document.querySelectorAll('.hero-slide');
  const carousel = document.getElementById('hero-carousel');
  const dots = document.querySelectorAll('.carousel-dot');
  const prevBtn = document.getElementById('prev-btn');
  const nextBtn = document.getElementById('next-btn');
  
  let currentIndex = 0;
  const totalSlides = slides.length;
  let startX = 0;
  let isDragging = false;

  // Aseguramos el tipo "number" para el index
  function updateSlider(index: number) {
    currentIndex = index;
    
    slides.forEach((slide, i) => {
      if (i === currentIndex) {
        slide.classList.add('active', 'opacity-100', 'z-10');
        slide.classList.remove('opacity-0', 'z-0');
      } else {
        slide.classList.remove('active', 'opacity-100', 'z-10');
        slide.classList.add('opacity-0', 'z-0');
      }
    });
    
    dots.forEach((dot, i) => {
      if (i === currentIndex) {
        dot.classList.add('bg-brand-primary');
        dot.classList.remove('bg-gray-300');
      } else {
        dot.classList.remove('bg-brand-primary');
        dot.classList.add('bg-gray-300');
      }
    });
  }

  function nextSlide() {
    updateSlider((currentIndex + 1) % totalSlides);
  }

  function prevSlide() {
    updateSlider((currentIndex - 1 + totalSlides) % totalSlides); 
  }

  if (prevBtn) prevBtn.addEventListener('click', prevSlide);
  if (nextBtn) nextBtn.addEventListener('click', nextSlide);

  if (carousel) {
    // Casteamos los eventos para evitar alertas de tipado al mezclarlos
    carousel.addEventListener('mousedown', dragStart as EventListener);
    window.addEventListener('mouseup', dragEnd as EventListener);
    carousel.addEventListener('touchstart', dragStart as EventListener, { passive: true });
    window.addEventListener('touchend', dragEnd as EventListener);
  }

  // Le decimos a TS que el evento (e) será del ratón o de la pantalla táctil
  function dragStart(e: MouseEvent | TouchEvent) {
    isDragging = true;
    // Evaluamos el tipo de evento y lo casteamos para acceder a pageX o touches
    if (e.type.includes('mouse')) {
      startX = (e as MouseEvent).pageX;
    } else {
      startX = (e as TouchEvent).touches[0].clientX;
    }
  }

  function dragEnd(e: MouseEvent | TouchEvent) {
    if (!isDragging) return;
    isDragging = false;
    
    let endX = 0;
    if (e.type.includes('mouse')) {
      endX = (e as MouseEvent).pageX;
    } else {
      endX = (e as TouchEvent).changedTouches[0].clientX;
    }
    
    const diff = startX - endX;

    if (Math.abs(diff) > 50) {
      if (diff > 0) nextSlide(); 
      else prevSlide();          
    }
  }

  // Le damos a e el tipo KeyboardEvent
  document.addEventListener('keydown', (e: KeyboardEvent) => {
    if(window.scrollY > 500) return; 
    if (e.key === 'ArrowLeft') prevSlide();
    else if (e.key === 'ArrowRight') nextSlide();
  });

  dots.forEach(dot => {
    // Usamos (e: Event) y e.currentTarget, y le ponemos || '0' por si acaso viene vacío
    dot.addEventListener('click', (e: Event) => {
      const target = e.currentTarget as HTMLElement;
      const index = parseInt(target.dataset.index || '0', 10);
      updateSlider(index);
    });
  });
</script>