<section class="relative pt-32 pb-20 lg:pt-48 lg:pb-32 overflow-hidden bg-[#F5F5F5]">
  <div class="hidden lg:flex flex-col gap-4 absolute left-6 top-1/2 -translate-y-1/2 z-10">
    <a href="#" class="w-10 h-10 rounded-lg bg-brand-primary text-white flex items-center justify-center hover:opacity-80 transition-opacity">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect width="4" height="12" x="2" y="9"/><circle cx="4" cy="4" r="2"/></svg>
    </a>
    <a href="#" class="w-10 h-10 rounded-lg bg-brand-primary text-white flex items-center justify-center hover:opacity-80 transition-opacity">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="20" x="2" y="2" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/></svg>
    </a>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="grid lg:grid-cols-2 gap-12 items-center">
      <div class="max-w-2xl">
        <h1 class="text-5xl lg:text-6xl font-extrabold leading-[1.1] mb-4 text-black">
          ¿Necesitas liquidez <br/> para tu pyme?
        </h1>
        <p class="text-xl text-brand-secondary mb-8 max-w-lg font-medium">
          En Capital Express te ayudamos.
        </p>
        <div class="flex flex-wrap gap-4">
          <a href="/enrolate" class="px-8 py-3 rounded-full bg-brand-primary text-white font-bold text-lg hover:opacity-90 transition-opacity flex items-center gap-2">
            haz la prueba hoy
          </a>
        </div>
      </div>

      <div class="relative flex justify-end">
        <div class="absolute right-0 top-1/2 -translate-y-1/2 w-[400px] h-[400px]">
          <div class="absolute inset-0 border-[60px] border-brand-primary rounded-full clip-half-left opacity-90"></div>
          <div class="absolute inset-8 border-[60px] border-[#E5E5E5] rounded-full clip-half-right opacity-80"></div>
        </div>
        <img src="https://images.unsplash.com/photo-1556761175-5973dc0f32d7?q=80&w=1632&auto=format&fit=crop" alt="Empresario usando tablet" class="relative z-10 rounded-full object-cover h-[500px] w-[350px] shadow-2xl border-8 border-white" referrerpolicy="no-referrer" />
      </div>
    </div>
  </div>
</section>