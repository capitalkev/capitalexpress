---
---
<section id="contactanos" class="py-24 bg-[#F5F5F5]">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12">
      <h2 class="text-5xl font-extrabold mb-4 uppercase tracking-tight text-black">CONTÁCTANOS</h2>
      <p class="text-xl text-brand-secondary uppercase tracking-wide">¡DÉJANOS TUS DATOS PARA INICIAR TU PROCESO DE FACTORING!</p>
    </div>

    <form id="contact-form" class="bg-transparent p-4 md:p-8">
      <div class="space-y-10">
        <div class="relative">
          <input type="text" name="name" required class="peer w-full border-b border-gray-400 bg-transparent py-2 text-brand-secondary focus:border-brand-primary focus:outline-none placeholder-transparent" placeholder="Nombre Contacto *" />
          <label class="absolute left-0 -top-3.5 text-sm text-brand-text transition-all peer-placeholder-shown:top-2 peer-placeholder-shown:text-base peer-focus:-top-3.5 peer-focus:text-sm peer-focus:text-brand-primary">Nombre Contacto *</label>
        </div>

        <div class="relative">
          <input type="text" name="ruc" required class="peer w-full border-b border-gray-400 bg-transparent py-2 text-brand-secondary focus:border-brand-primary focus:outline-none placeholder-transparent" placeholder="RUC Empresa *" />
          <label class="absolute left-0 -top-3.5 text-sm text-brand-text transition-all peer-placeholder-shown:top-2 peer-placeholder-shown:text-base peer-focus:-top-3.5 peer-focus:text-sm peer-focus:text-brand-primary">RUC Empresa *</label>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-10">
          <div class="relative">
            <input type="email" name="email" required class="peer w-full border-b border-gray-400 bg-transparent py-2 text-brand-secondary focus:border-brand-primary focus:outline-none placeholder-transparent" placeholder="Correo Electrónico *" />
            <label class="absolute left-0 -top-3.5 text-sm text-brand-text transition-all peer-placeholder-shown:top-2 peer-placeholder-shown:text-base peer-focus:-top-3.5 peer-focus:text-sm peer-focus:text-brand-primary">Correo Electrónico *</label>
          </div>
          <div class="relative">
            <input type="tel" name="phone" required class="peer w-full border-b border-gray-400 bg-transparent py-2 text-brand-secondary focus:border-brand-primary focus:outline-none placeholder-transparent" placeholder="Teléfono *" />
            <label class="absolute left-0 -top-3.5 text-sm text-brand-text transition-all peer-placeholder-shown:top-2 peer-placeholder-shown:text-base peer-focus:-top-3.5 peer-focus:text-sm peer-focus:text-brand-primary">Teléfono *</label>
          </div>
        </div>

        <div class="flex flex-col sm:flex-row gap-8 text-sm text-brand-secondary pt-2">
          <label class="flex items-center gap-2 cursor-pointer">
            <input type="checkbox" name="privacy" required class="w-4 h-4 text-brand-primary rounded border-gray-400 focus:ring-brand-primary" />
            <span>Acepto la <a href="/terminos-y-condiciones-generales" target="_blank" class="text-blue-500 hover:underline">política de privacidad</a>.</span>
          </label>
          <label class="flex items-center gap-2 cursor-pointer">
            <input type="checkbox" name="hasExec" class="w-4 h-4 text-brand-primary rounded border-gray-400 focus:ring-brand-primary" />
            <span>Ya tengo ejecutivo.</span>
          </label>
        </div>

        <div class="relative pt-4">
          <textarea name="message" required rows="4" class="w-full border border-gray-400 bg-transparent p-4 text-brand-secondary focus:border-brand-primary focus:ring-1 focus:ring-brand-primary focus:outline-none resize-none" placeholder="Mensaje *"></textarea>
        </div>

        <div class="pt-2">
          <button id="contact-btn" type="submit" class="px-12 py-2 bg-black text-white rounded-full font-bold hover:bg-gray-800 transition-colors disabled:opacity-70">
            Solicitar contacto
          </button>
        </div>

        <p id="contact-success" class="hidden text-green-600 font-medium bg-green-50 p-3 rounded-lg mt-4">¡Gracias! Hemos recibido tu solicitud.</p>
        <p id="contact-error" class="hidden text-red-600 font-medium bg-red-50 p-3 rounded-lg mt-4">Hubo un error al enviar. Intenta nuevamente.</p>
      </div>
    </form>
  </div>
</section>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const btn = document.getElementById('contact-btn') as HTMLButtonElement;
  const successMsg = document.getElementById('contact-success');
  const errorMsg = document.getElementById('contact-error');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    btn.disabled = true;
    btn.textContent = 'Enviando...';
    successMsg?.classList.add('hidden');
    errorMsg?.classList.add('hidden');

    const formData = new FormData(form);
    const data: Record<string, any> = Object.fromEntries(formData.entries());
    data.privacy = formData.get('privacy') === 'on';
    data.hasExec = formData.get('hasExec') === 'on';

    try {
      const res = await fetch('/api/contact', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data)
      });
      if (res.ok) {
        successMsg?.classList.remove('hidden');
        form.reset();
      } else {
        errorMsg?.classList.remove('hidden');
      }
    } catch (err) {
      errorMsg?.classList.remove('hidden');
    } finally {
      btn.disabled = false;
      btn.textContent = 'Solicitar contacto';
    }
  });
</script>